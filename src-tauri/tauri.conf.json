{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlashPad",
  "version": "0.8.4",
  "identifier": "therbbt.flashpad",
  "build": {
    "beforeDevCommand": "npm install && npm run dev",
    "beforeBuildCommand": "npm install && npm run build",
    "devUrl": "http://127.0.0.1:5166",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FlashPad",
        "width": 760,
        "height": 580,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "therbbt",
    "copyright": "Copyright © 2026 therbbt",
    "shortDescription": "Global-hotkey quick-notes app",
    "longDescription": "FlashPad is a global-hotkey quick-notes desktop app. Press a hotkey from anywhere to pop open a lightweight notepad, jot something down in a tree of notes, and hide it again.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/therbbt/FlashPad/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFRTIyMEZBQzRFMTk5NEQKUldSTm1lSEUraURpZm03VjhuTUhLRWg3d0l6d0R5MHlpOXRzb0NveVVuTE5YZS8ybU5lSDVkbjkK"
    }
  }
}