{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlashPad",
  "version": "0.1.0",
  "identifier": "com.flashpad.app",
  "build": {
    "beforeDevCommand": "export PATH=\"$PWD/.local/node/bin:$PATH\" && npm install && npm run dev",
    "beforeBuildCommand": "export PATH=\"$PWD/.local/node/bin:$PATH\" && npm install && npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FlashPad",
        "width": 760,
        "height": 580,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}